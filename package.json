{
  "name": "dc-explorer",
  "version": "1.0.0",
  "description": "Guardx — Independent verifiable security auditor for EigenCloud TEE applications",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "server": "tsx src/server.ts",
    "server:build": "tsc && node dist/server.js",
    "dev": "tsx src/server.ts",
    "web": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web",
    "web:start": "npm run start --prefix web"
  },
  "keywords": ["docker", "layers", "registry", "docker-hub"],
  "license": "MIT",
  "dependencies": {
    "@layr-labs/ai-gateway-provider": "^1.0.1",
    "ai": "^6.0.168",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "tar-stream": "^3.1.7",
    "viem": "^2.46.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/tar-stream": "^3.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
